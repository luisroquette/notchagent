<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="using:NotchAgent.Windows.UI"
        x:Class="NotchAgent.Windows.UI.FloatingBarWindow"
        x:DataType="ui:BarViewModel"
        Title="NotchAgent"
        SizeToContent="WidthAndHeight"
        SystemDecorations="None"
        CanResize="False"
        ShowInTaskbar="False"
        ShowActivated="False"
        Topmost="True"
        Background="Transparent"
        WindowStartupLocation="Manual"
        TransparencyLevelHint="Transparent">
  <Border Name="Chassis" BorderBrush="#DA7757" BorderThickness="0,0,0,3" Background="#16161B"
          CornerRadius="0,0,10,10">
    <Grid>

      <!-- Compact strip: always the entry point, click toggles pin. -->
      <ui:CompactBarView Name="CompactPanel" PointerPressed="OnCompactClicked"/>

      <!-- Expanded panel: same content the old popover had. -->
      <DockPanel Name="ExpandedPanel" Margin="14" IsVisible="False">

        <Grid DockPanel.Dock="Top" ColumnDefinitions="Auto,*,Auto" Margin="0,0,0,10">
          <TextBlock Grid.Column="0" Text="NOTCHAGENT" FontWeight="Bold" FontSize="13"
                     Foreground="#DA7757" LetterSpacing="2"/>
          <TextBlock Grid.Column="2" Text="{Binding UpdatedText}" FontSize="10" Foreground="#6BFFFFFF"
                     VerticalAlignment="Center"/>
        </Grid>

        <Border DockPanel.Dock="Top" Margin="0,0,0,8" Padding="8,5" CornerRadius="6"
                Background="#1AFFFFFF" IsVisible="{Binding HasBanner}">
          <TextBlock Text="{Binding BannerText}" Foreground="{Binding BannerColor}" FontSize="11" FontWeight="SemiBold"/>
        </Border>

        <Grid DockPanel.Dock="Bottom" ColumnDefinitions="Auto,Auto,*,Auto,Auto" Margin="0,10,0,0">
          <Button Grid.Column="0" Content="Refresh" Click="OnRefreshClick" Classes="chip"/>
          <Button Grid.Column="1" Content="{Binding PauseLabel}" Click="OnPauseClick" Classes="chip" Margin="6,0,0,0"/>
          <Button Grid.Column="3" Content="Settings" Click="OnSettingsClick" Classes="chip"/>
          <Button Grid.Column="4" Content="Quit" Click="OnQuitClick" Classes="chip" Margin="6,0,0,0"/>
        </Grid>

        <ui:RunnerControl DockPanel.Dock="Bottom" Height="24" Margin="0,8,0,0"
                           UsedPercent="{Binding RunnerUsedPercent}"
                           IsGameOver="{Binding RunnerGameOver}"
                           ResetsAt="{Binding RunnerResetsAt}"
                           ObstacleTint="{Binding RunnerObstacleTint}"/>

        <Grid ColumnDefinitions="*,10,*">
          <ContentControl Grid.Column="0" Content="{Binding Claude}">
            <ContentControl.ContentTemplate>
              <DataTemplate>
                <ui:ProviderCardView/>
              </DataTemplate>
            </ContentControl.ContentTemplate>
          </ContentControl>
          <ContentControl Grid.Column="2" Content="{Binding Codex}">
            <ContentControl.ContentTemplate>
              <DataTemplate>
                <ui:ProviderCardView/>
              </DataTemplate>
            </ContentControl.ContentTemplate>
          </ContentControl>
        </Grid>
      </DockPanel>
    </Grid>
  </Border>

  <Window.Styles>
    <Style Selector="Button.chip">
      <Setter Property="Background" Value="#20202D"/>
      <Setter Property="Foreground" Value="#9EFFFFFF"/>
      <Setter Property="Padding" Value="10,5"/>
      <Setter Property="CornerRadius" Value="14"/>
      <Setter Property="FontSize" Value="11"/>
    </Style>
  </Window.Styles>
</Window>
